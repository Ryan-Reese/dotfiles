[user]
	name = Ryan-Reese
	email = ryreese@nvidia.com 
	signingkey = ~/.ssh/main.pub
[core]
	editor = nvim
	whitespace = error
[init]
	defaultBranch = main
[status]
	branch = true
	showStash = true
[log]
	decorate = short
[diff]
	renames = copies
	algorithm = histogram
[merge]
	conflictStyle = diff3
[push]
	default = nothing
[rerere]
	enabled = true
[pull]
	rebase = true
[fetch]
	prune = true
[branch]
	sort = -committerdate
[column]
	ui = auto
[rebase]
	autoStash = true
[alias]
    tree = log --graph --decorate --pretty=oneline --abbrev-commit --all
[commit]
	gpgSign = true
[gpg]
	format = ssh
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
